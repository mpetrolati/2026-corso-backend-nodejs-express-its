# Copia questo file in `.env` e metti i tuoi valori veri.
# Il `.env` non viene committato (vedi .gitignore).

# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/app.db

# JWT (li useremo nel Giorno 3)
JWT_SECRET=metti-qui-una-stringa-lunga-e-casuale-di-almeno-32-caratteri
JWT_EXPIRES_IN=1h

# Bcrypt
BCRYPT_ROUNDS=10
